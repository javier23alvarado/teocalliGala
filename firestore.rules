rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Verifica si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Obtiene los datos del perfil del usuario que realiza la petición
    function requestUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    
    // Helper: Verifica si el usuario que hace la petición está activo y es super_admin
    function isSuperAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
             requestUserData().activo == true && 
             requestUserData().rol == "super_admin";
    }

    match /usuarios/{userId} {
      
      // Lectura:
      // - Cualquier usuario autenticado puede leer su propio perfil si está activo.
      // - El Super Administrador activo puede leer cualquier perfil.
      // - Regla estricta: Si el documento tiene 'activo == false', se bloquea el acceso de lectura al propio usuario.
      allow read: if isAuthenticated() && (
        (request.auth.uid == userId && resource.data.activo == true) || 
        isSuperAdmin()
      );
      
      // Escritura (crear, actualizar, borrar):
      // - Únicamente permitido para el Super Administrador activo.
      allow write: if isSuperAdmin();
    }
  }
}
